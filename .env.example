DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linkedin_automation
REDIS_URL=redis://localhost:6379
ENCRYPTION_KEY=          # 32-byte hex key for AES-256-GCM cookie encryption
PROXY_PROVIDER_API_KEY=
# Webhook URL for checkpoint/alert notifications (Slack, Discord, n8n, etc.)
# POST body: { "text": "..." }  — compatible with Slack incoming webhooks
ALERT_WEBHOOK_URL=
NODE_ENV=development
HEADLESS=false           # Always false in prod — use Xvfb
PORT=3001

# CORS: comma-separated list of allowed dashboard origins in production
# Example: ALLOWED_ORIGINS=https://dashboard.example.com
ALLOWED_ORIGINS=http://localhost:3000
