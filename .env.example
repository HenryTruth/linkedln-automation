# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linkedin_automation

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
# 64-char hex string for AES-256-GCM cookie encryption.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Browser ───────────────────────────────────────────────────────────────────
# Must be false in production — LinkedIn detects headless mode.
# Use Xvfb (configured in the API Dockerfile) to provide a virtual display.
HEADLESS=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Local dev defaults to starting queue workers inside the API process.
# In production, run `pnpm --filter @linkedin-automation/queue workers`
# as a separate worker service, or set START_WORKERS=true for a single-service deploy.
START_WORKERS=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. In production set to your dashboard URL.
ALLOWED_ORIGINS=http://localhost:3000

# ── Dashboard (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Alerts (optional) ─────────────────────────────────────────────────────────
# Webhook URL for checkpoint/anomaly/proxy alerts (Slack, Discord, generic).
# POST body: { "text": "..." }
ALERT_WEBHOOK_URL=

# Email alert fallback via Resend (used when ALERT_WEBHOOK_URL is not set).
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=
ALERT_EMAIL_TO=
# Optional: custom from address (must be a verified Resend domain in production).
# Defaults to alerts@resend.dev (Resend shared domain, good for testing only).
ALERT_EMAIL_FROM=
